# ENML environment template
# Copy to .env and adjust for your machine.

# Root paths
ENML_ROOT=./
MEMORY_ROOT=./memory

# Local file access policy
ALLOWED_PATHS=/home/user/Projects,/home/user/Documents

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_KNOWLEDGE_COLLECTION=knowledge_collection
QDRANT_CONVERSATION_COLLECTION=conversation_collection
QDRANT_RESEARCH_COLLECTION=research_collection
QDRANT_PROJECT_COLLECTION=project_collection
QDRANT_PROFILE_COLLECTION=profile_collection
QDRANT_DOCUMENT_COLLECTION=document_collection
QDRANT_EPISODIC_COLLECTION=episodic_collection

# Embedding / reranking
EMBED_MODEL=BAAI/bge-base-en-v1.5
EMBED_DIM=768

# llama.cpp
MODELS_DIR=/home/user/ai-models
LLAMA_SERVER=/home/user/Tools/llama.cpp/build/bin/llama-server
LLAMA_FIT_PARAMS=/home/user/Tools/llama.cpp/build/bin/llama-fit-params
LLAMA_SERVER_URL=http://localhost:8080
# Deprecated fallback only used if the launch planner is unavailable.
CONTEXT_SIZE=4096
FIT_CONTEXT_MIN=1024
FIT_CONTEXT_STEP=256
FIT_TARGET_MB=512
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=q8_0

# Persona
AI_NAME=ENML Assistant
AI_HINT=running on local hardware

# Input / extraction tuning
MAX_REALTIME_INPUT_CHARS=500
MAX_FACTS_PER_EXTRACTION=10
MAX_DOCUMENT_FACTS=25
MAX_DOCUMENT_SUMMARIES=15
MIN_RETRIEVAL_CONFIDENCE=0.30

# Prompt budgets
PROMPT_BUDGET_SYSTEM=400
PROMPT_BUDGET_MEMORY=1200
PROMPT_BUDGET_DOCUMENTS=2000
PROMPT_BUDGET_USER=200

# Model routing defaults
DEFAULT_CHAT_MODEL=Meta-Llama-3-8B-Instruct
FAST_CHAT_MODEL=Meta-Llama-3-8B-Instruct
CODING_CHAT_MODEL=Meta-Llama-3-8B-Instruct
REASONING_CHAT_MODEL=Meta-Llama-3-8B-Instruct

# Web UI
WEB_SERVER_PORT=5000

# Debugging
ENML_DEBUG=0
